<Window x:Class="PDC_System.Payroll_Details.AddManualLoanEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        
        AllowsTransparency="True"
 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:cal="clr-namespace:ModernCalendarLib;assembly=ModernCalendarLib"
        Background="{DynamicResource Background}" Foreground="{DynamicResource Forground}"
        Title="Manual Loan Entry" Height="auto" Width="380" WindowStartupLocation="CenterScreen">




    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
               CornerRadius="10"
                         
               ResizeBorderThickness="6"
               GlassFrameThickness="0"
               NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>


    <Grid>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="6" >

            <Grid>


                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <Border Margin="5"  x:Name="TitleBar" Grid.Row="0"
Background="{DynamicResource Background}" 
>
                    <DockPanel>
                        <!-- App Logo -->
                        <Image Source="/Assets/MainLogo.png"  Height="20" Width="20" Margin="8,0"/>
                        <!-- App Title -->
                        <TextBlock x:Name="PDCtitel" Text="Loan Entry" Foreground="{DynamicResource Forground}"  VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Control Panel -->



                        <!-- Title bar buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Minimize" Content="—" Width="25" Height="25" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}"/>
                            <Button x:Name="Maximize" Content="🗖" Width="25" Height="25" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                            <Button x:Name="Colose" Content="🗙" Width="25" Height="25" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                        </StackPanel>



                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="Manual Loan Entry"
                FontSize="22"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                Margin="0 0 0 15"/>

                    <!-- Input Fields -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top" >

                        <!-- Employee ID -->
                        <TextBlock Text="Employee ID" FontWeight="SemiBold"/>
                        <TextBlock x:Name="EmployeeIdBox"
                  Margin="0 5 0 15"
                  Height="30"
                  />

                        <!-- Employee Name -->
                        <TextBlock Text="Employee Name" FontWeight="SemiBold"/>
                        <TextBlock x:Name="EmployeeNameBox"
                  Margin="0 5 0 15"
                  Height="30"
                 />

                        <!-- Current Remaining -->
                        <TextBlock Text="Current Remaining Amount" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentRemainingBox"
                  Margin="0 5 0 15"
                  Height="30"
                  FontWeight="Bold"/>

                        <!-- Monthly Installment -->
                        <TextBlock Text="Monthly Installment" FontWeight="SemiBold"/>
                        <TextBlock x:Name="MonthlyInstallmentBox"
                  Margin="0 5 0 15"
                  Height="30"
                  
                  
                  FontWeight="Bold"/>

                        <!-- Paid amount -->
                        <TextBlock Text="Paid Amount" FontWeight="SemiBold"/>
                        <TextBox x:Name="PaidAmountBox"
                  Margin="0 5 0 15"
                  Style="{DynamicResource TextBoxStyle}"
                 />

                        <!-- Date Picker -->
                        <TextBlock Text="Date" FontWeight="SemiBold"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}" Width="255" BorderThickness="2" CornerRadius="5">
                            <cal:CustomDatePicker x:Name="DatePicker"  Width="250"/>
                        </Border>

                        <!-- Month -->



                    </StackPanel>

                    <!-- Save Button -->
                    <Button Grid.Row="2"
             Content="Save Entry"
            Width="100"
           Style="{DynamicResource ActionButton}"
             FontWeight="SemiBold"
             Margin="0 15 0 0"
             Click="Save_Click"/>
                </Grid>

            </Grid>

        </Border>
    </Grid>



   
</Window>
