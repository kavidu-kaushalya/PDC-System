<Window x:Class="PDC_System.AddErningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Add Earning"
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        AllowsTransparency="True"
        WindowStyle="None"
         xmlns:cal="clr-namespace:ModernCalendarLib;assembly=ModernCalendarLib"
        Height="420" Width="550"
        Foreground="{DynamicResource Forground}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Background}">


    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
            CornerRadius="10"
                      
            ResizeBorderThickness="6"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>



    <Grid>

        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="6" >

            <Grid>


                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <Border Margin="5"  x:Name="TitleBar" Grid.Row="0"
Background="{DynamicResource Background}" 
>
                    <DockPanel>
                        <!-- App Logo -->
                        <Image Source="/Assets/MainLogo.png"  Height="20" Width="20" Margin="8,0"/>
                        <!-- App Title -->
                        <TextBlock x:Name="PDCtitel" Text="Add Earnings" Foreground="{DynamicResource Forground}"  VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Control Panel -->



                        <!-- Title bar buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Minimize" Content="—" Width="25" Height="25" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}"/>
                            <Button x:Name="Maximize" Content="🗖" Width="25" Height="25" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                            <Button x:Name="Colose" Content="🗙" Width="25" Height="25" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                        </StackPanel>



                    </DockPanel>
                </Border>



                <Grid Grid.Row="1">

                    <!-- Center Card Layout -->
                    <Border Background="{DynamicResource Background}"
                Padding="25"
                CornerRadius="10"
                Width="auto"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="2">

                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Employee -->
                            <TextBlock Text="Employee:"
                           Grid.Row="0" Grid.Column="0"
                           VerticalAlignment="Center"/>
                            <ComboBox x:Name="EmployeeCombo"
                          Grid.Row="0" Grid.Column="1"
                          Width="220"
                          Style="{DynamicResource ComboBoxFlatStyle}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="EmployeeId"/>

                            <!-- Description -->
                            <TextBlock Text="Description:"
                           Grid.Row="1" Grid.Column="0"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"/>
                            <TextBox x:Name="EarningDescription"
                         Grid.Row="1" Grid.Column="1"
                         Style="{DynamicResource TextBoxStyle}"
                         Width="220"
                         Margin="0,12,0,0"/>

                            <!-- Amount -->
                            <TextBlock Text="Amount:"
                           Grid.Row="2" Grid.Column="0"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"/>
                            <TextBox x:Name="EarningAmount"
                         Grid.Row="2" Grid.Column="1"
                         Width="220"
                         Style="{DynamicResource TextBoxStyle}"
                         Margin="0,12,0,0"/>

                            <!-- Date -->
                            <TextBlock Text="Date:"
                           Grid.Row="3" Grid.Column="0"
                           Margin="0,12,0,0"
                           VerticalAlignment="Center"/>

                            <Border BorderBrush="{DynamicResource BorderBrush}" Margin="5" Grid.Row="3" Grid.Column="1" BorderThickness="2" CornerRadius="5">
                                <cal:CustomDatePicker x:Name="EarningDate"  Width="250"/>
                            </Border>


                            <!-- Save Button -->
                            <Button Content="Save"
                        Grid.Row="4" Grid.ColumnSpan="2"
                        Width="120" Height="35"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Center"
                        Style="{DynamicResource ActionButton}"
                        FontWeight="Bold"
                        Click="Save_Click"/>
                        </Grid>

                    </Border>
                </Grid>

            </Grid>


        </Border>
    </Grid>



</Window>