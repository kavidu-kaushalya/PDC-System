<Window x:Class="PDC_System.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True" WindowStyle="None"
         xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Print Preview" Height="650" Width="950" Foreground="{DynamicResource Forground}" Background="{DynamicResource Background}"
        WindowStartupLocation="CenterScreen">


    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
               CornerRadius="10"
                         
               ResizeBorderThickness="6"
               GlassFrameThickness="0"
               NonClientFrameEdges="None"/>
    </shell:WindowChrome.WindowChrome>




    <Grid>


        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="6" >

            <Grid>


                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <Border Margin="5"  x:Name="TitleBar" Grid.Row="0"
Background="{DynamicResource Background}" 
>
                    <DockPanel>
                        <!-- App Logo -->
                        <Image Source="/Assets/MainLogo.png"  Height="20" Width="20" Margin="8,0"/>
                        <!-- App Title -->
                        <TextBlock x:Name="PDCtitel" Text="Job Card" Foreground="{DynamicResource Forground}"  VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Control Panel -->



                        <!-- Title bar buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="Minimize" Content="—" Width="25" Height="25" Click="Minimize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}"/>
                            <Button x:Name="Maximize" Content="🗖" Width="25" Height="25" Click="Maximize_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                            <Button x:Name="Colose" Content="🗙" Width="25" Height="25" Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" Margin="5" Background="Transparent" Style="{DynamicResource NavigationButtonStyle}" BorderBrush="{x:Null}" />
                        </StackPanel>



                    </DockPanel>
                </Border>



                <Grid Grid.Row="1" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL -->
                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="Select Printer:" FontWeight="Bold"/>
                        <ComboBox x:Name="PrinterCombo" Style="{DynamicResource ComboBoxFlatStyle}" Margin="0,5,0,15"/>
                        <Button Style="{StaticResource ActionButton}" x:Name="SettingsBtn"
        Content="Printer Settings"
        Width="120"
        Margin="5"
        Click="SettingsBtn_Click"/>


                        <StackPanel Orientation="Horizontal" Margin="10">
                            <TextBlock Text="Width:" VerticalAlignment="Center"/>
                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="PaperWidthBox" Width="60" Margin="5,0"/>

                            <TextBlock Text="Height:" VerticalAlignment="Center"/>
                            <TextBox Style="{DynamicResource TextBoxStyle}" x:Name="PaperHeightBox" Width="60" Margin="5,0"/>

                            <ComboBox x:Name="UnitCombo" Style="{DynamicResource ComboBoxFlatStyle}" Width="70" Margin="5,0">
                                <ComboBoxItem Content="mm" />
                                <ComboBoxItem Content="cm"/>
                                <ComboBoxItem Content="inch" IsSelected="True"/>
                            </ComboBox>
                        </StackPanel>





                        <Button Style="{DynamicResource ActionButton}" Content="Print"  Margin="0,20,0,0" Click="Print_Click"/>
                    </StackPanel>

                    <!-- PREVIEW -->
                    <Border Grid.Column="1" BorderBrush="Gray" CornerRadius="10" Background="White" BorderThickness="1" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage"/>
                        </ScrollViewer>
                    </Border>

                </Grid>

            </Grid>
        </Border>

    </Grid>
    
    
    
    
    
    
    

</Window>
